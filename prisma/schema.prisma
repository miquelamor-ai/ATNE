generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// MEMÒRIA D'ALUMNE
// ============================================
model StudentMemory {
  id                  String   @id @default(cuid())
  nom                 String
  paisOrigen          String?
  llenguaL1           String?
  alfabetitzacioLlatina String?
  nivellMECR          String?
  necessitatsSuport   String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("aau_student_memory")
}

// ============================================
// MEMÒRIA DE CLASSE
// ============================================
model ClassMemory {
  id                    String   @id @default(cuid())
  nom                   String
  configuracioMultinivell Boolean @default(false)
  estilSuportPreferit   String   @default("mixt")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("aau_class_memory")
}

// ============================================
// PERFIL DE MATÈRIA (Content Knowledge)
// ============================================
model SubjectProfile {
  id                String   @id @default(cuid())
  nomAssignatura    String
  estilRedaccio     String   @default("cientific")
  termesIntocables  String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("aau_subject_profile")
}

// ============================================
// ADAPTACIÓ
// ============================================
model Adaptation {
  id                String   @id @default(cuid())

  // Text original
  textOriginal      String
  fontText           String?

  // Configuració
  edat              String?
  nivellDificultat  String?
  ajuts             String?
  traduccio         String?
  taulaComparativa  Boolean  @default(true)
  modeMultinivell   Boolean  @default(false)

  // Memòries associades (referències opcionals)
  studentMemoryId   String?
  classMemoryId     String?
  subjectProfileId  String?

  // Resultats
  textAdaptat       String?
  textAcces         String?
  textEnriquiment   String?
  traduccioText     String?
  auditoria         String?
  taulaComparativaData String?
  pictograms        String?
  glossari          String?

  // Feedback
  feedbackDocent    String?
  valoracio         Int?

  // BD compartida
  tags              String?
  assignatura       String?
  isPublic          Boolean  @default(true)

  // Metadades
  createdVia        String?
  modelAdaptador    String?
  modelAuditor      String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("aau_adaptation")
}

// ============================================
// CONFIGURACIÓ DE L'APP
// ============================================
model AppSettings {
  id                String   @id @default("default")
  modelAdaptador    String   @default("gemini-2.0-flash")
  modelAuditor      String   @default("gemini-2.0-flash")
  modelTraductor    String   @default("gemini-2.0-flash")
  modelOrquestrador String   @default("gemini-2.0-flash")
  updatedAt         DateTime @updatedAt

  @@map("aau_app_settings")
}
